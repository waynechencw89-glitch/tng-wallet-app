# 复制这个文件为 .env，然后填入真实的值
# 注意：.env 文件绝对不能上传到 GitHub！

# Supabase（在 Supabase Dashboard > Settings > API 找到）
SUPABASE_URL=https://你的项目id.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...（anon public key）
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...（service_role key，绝对要保密！）

# 你的 Vercel 前端网址（部署后填入）
FRONTEND_URL=https://你的项目.vercel.app
